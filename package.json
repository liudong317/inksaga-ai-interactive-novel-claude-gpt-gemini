{
  "name": "inksaga",
  "version": "1.0.0",
  "description": "InkSaga 墨叙 - AI 互动小说桌面应用",
  "main": "src/main.js",
  "scripts": {
    "start": "chcp 65001 && electron .",
    "build": "node src/build.js",
    "build:oss": "electron-builder --win --x64"
  },
  "keywords": ["ai-novel", "interactive-fiction", "openai-compatible", "claude", "gpt", "electron", "inksaga"],
  "author": "liudong317 <liudongwyyx@163.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liudong317/inksaga-ai-interactive-novel-claude-gpt-gemini.git"
  },
  "homepage": "https://github.com/liudong317/inksaga-ai-interactive-novel-claude-gpt-gemini#readme",
  "bugs": {
    "url": "https://github.com/liudong317/inksaga-ai-interactive-novel-claude-gpt-gemini/issues"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "javascript-obfuscator": "^4.1.0"
  },
  "build": {
    "appId": "com.inksaga.app",
    "productName": "InkSaga",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "src/assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "asar": false
  }
}

